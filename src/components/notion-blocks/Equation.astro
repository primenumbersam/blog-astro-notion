---
import katex from 'katex';

const { block } = Astro.props;
let expression = '';

if (block.equation && block.equation.expression) {
    expression = block.equation.expression;
}

let html = expression;
try {
  html = katex.renderToString(expression, { throwOnError: false, displayMode: true });
} catch (e) {
  console.error('KaTeX error:', e);
}
---
<div class="notion-equation" set:html={html} />
